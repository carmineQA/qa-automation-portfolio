{
  "name": "qa-automation-portfolio",
  "version": "1.0.0",
  "description": "Personal project to build a modern test automation portfolio using Playwright and TypeScript.\r It covers three progressive levels: SauceDemo (UI), Restful Booker (API), Automation Exercise (full E2E).\r Stack: Playwright + TypeScript, paired with Claude as an AI mentor/assistant throughout development.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression --project=chromium --project=firefox --project=webkit --project=api",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carmineQA/qa-automation-portfolio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/carmineQA/qa-automation-portfolio/issues"
  },
  "homepage": "https://github.com/carmineQA/qa-automation-portfolio#readme",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.5",
    "prettier": "^3.9.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "zod": "^4.4.3"
  }
}
